  ) %>%
  mutate(Year = "2022")


# Bind and arrange summary statistics by Year and Sex 
summary_all <- bind_rows(summary_2019, summary_2022) %>%
  mutate(SEX = factor(SEX, levels = c("Male", "Female"))) %>%
  arrange(Year, SEX) %>%
  select(Year, SEX, Count, Mean, Median, Mode, Min, Max, SD)

# Merge summary statistics
