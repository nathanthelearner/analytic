    Mode = as.numeric(names(sort(table(Q33), decreasing = TRUE)[1])),
    Min = min(Q33, na.rm = TRUE),
    Max = max(Q33, na.rm = TRUE),
    SD = sd(Q33, na.rm = TRUE)
  ) %>%
  mutate(Year = "2019")


# For 2022
summary_2022 <- Jul2022_sample %>%
  filter(Q33 != 999, !is.na(Q33), !is.na(SEX)) %>%
  group_by(SEX) %>%
  summarise(
    Count = n(),
    Mean = mean(Q33, na.rm = TRUE),
